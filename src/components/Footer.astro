---
import { type Language, t } from '../lib/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const getUrl = (path: string) => `/${lang}${path}`;
---

<footer class="foot">
  <div class="foot-inner shell">
    <div class="foot-col">
      <div class="foot-mark">Kocziha Mihály</div>
      <div>Head of Consulting · SMP Solutions</div>
      <div>© 2026 · koczihamihaly.com</div>
    </div>
    <div class="foot-col">
      <a href={getUrl('/writing')}>{t('writing', lang)}</a>
      <a href={getUrl('/about')}>{t('about', lang)}</a>
      <a href={getUrl('/speaking')}>{t('speaking', lang)}</a>
      <a href={getUrl('/contact')}>{t('contact', lang)}</a>
    </div>
    <div class="foot-col">
      <a href="mailto:mihaly.kocziha@smp.hu">mihaly.kocziha@smp.hu</a>
      <a href="https://www.linkedin.com/in/kocziham/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={getUrl('/rss.xml')}>{t('rss', lang)}</a>
    </div>
  </div>
</footer>
