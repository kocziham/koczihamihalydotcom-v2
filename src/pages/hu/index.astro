---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayRow from '../../components/EssayRow.astro';
import { getEssays } from '../../lib/essays';

const essays = await getEssays('hu');
const latestEssays = essays.slice(0, 3);

const meta = {
  title: 'Kocziha Mihály — AI irányítás a bankoknak',
  description: 'Kocziha Mihály, az SMP Solutions tanácsadási igazgatójának weboldala. Írások az AI irányításról, a generatív rendszerekről szabályozott környezetben, és az AI-transzformáció valódi valóságáról a bankászetban.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="hu">
  <section class="home shell">
    <div class="home-mark">Vezető tanácsadó · Banki AI</div>
    <h1 class="home-stmt">
      Segítem a magyar és CEE bankokat AI-t <em>felelősen</em> bevezetni.
    </h1>
    <p class="home-sub">
      Írások az AI irányításról, generatív rendszerekről szabályozott környezetben, és az AI-transzformáció valódi valóságáról a bankászetban. Hosszú forma, lassan, időnként.
    </p>

    <div class="home-grid">
      <div class="home-grid-label">Legutóbbi írások</div>
      <div>
        <div class="essay-list">
          {latestEssays.map(essay => (
            <EssayRow
              title={essay.data.title}
              description={essay.data.description}
              date={essay.data.date}
              slug={essay.data.slug}
              pillar={essay.data.pillar}
              languages={[essay.data.language]}
              lang="hu"
            />
          ))}
        </div>

        <div class="home-cta">
          <a href="/hu/writing/" class="btn-link btn-arrow">Összes írás</a>
          <span style="margin: 0 12px; color: var(--color-rule-strong);">·</span>
          Megkeresésekhez: <a href="/hu/contact">kapcsolat</a>. Alkalmi megjegyzések a <a href="https://www.linkedin.com/in/koczihamilay/" target="_blank" rel="noopener noreferrer">LinkedIn</a>-en.
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding-top: var(--space-20);
    padding-bottom: var(--space-32);
  }

  .home-mark {
    font-family: var(--font-sans);
    font-size: var(--fs-13);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .home-stmt {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 8vw, 3.25rem);
    line-height: var(--lh-tight);
    font-weight: var(--fw-medium);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-10) 0;
  }

  .home-stmt em {
    font-style: italic;
    color: var(--color-accent);
  }

  .home-sub {
    font-family: var(--font-serif);
    font-size: var(--fs-22);
    line-height: var(--lh-snug);
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-16) 0;
    max-width: var(--measure-essay);
  }

  .home-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-10);
    margin-top: var(--space-16);
  }

  .home-grid-label {
    font-family: var(--font-sans);
    font-size: var(--fs-13);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }

  .home-cta {
    margin-top: var(--space-10);
    font-size: var(--fs-14);
    color: var(--color-text-muted);
  }

  .home-cta a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .home-cta a:hover {
    text-decoration: underline;
  }

  .btn-link {
    font-weight: var(--fw-medium);
  }

  @media (max-width: 820px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .home-grid-label {
      display: none;
    }

    .home {
      padding-top: var(--space-10);
    }
  }
</style>
