---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Előadások — Kocziha Mihály',
  description: 'Előadások és workshop meghívások.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="hu" currentNav="speaking">
  <div class="shell-index" style="padding-top: var(--space-20); padding-bottom: var(--space-32);">
    <h1 style="font-family: var(--font-serif); font-size: var(--fs-40); margin: 0 0 var(--space-10) 0;">Előadások</h1>

    <section class="speaking-section">
      <div class="speaking-section-head">
        <span class="label">Hamarosan</span>
        <span class="count">00 / 05</span>
      </div>
      <div class="speak-empty">
        Jelenleg semmi sincs az naptáron.
        <span class="speak-empty-cta">
          Esemény javaslatához, <a href="/hu/contact">írj nekem</a>.
        </span>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .speaking-section {
    margin-bottom: var(--space-16);
  }

  .speaking-section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
    font-size: var(--fs-13);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .speak-empty {
    font-family: var(--font-serif);
    font-size: var(--fs-19);
    font-style: italic;
    color: var(--color-text-faint);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }

  .speak-empty-cta {
    display: block;
    margin-top: var(--space-3);
  }

  .speak-empty-cta a {
    color: var(--color-accent);
  }
</style>
