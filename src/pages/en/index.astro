---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayRow from '../../components/EssayRow.astro';
import { getEssays } from '../../lib/essays';
import { t } from '../../lib/i18n';

const essays = await getEssays('en');
const latestEssays = essays.slice(0, 3);

const meta = {
  title: 'Kocziha Mihály — AI governance for banks',
  description: 'Editorial site of Kocziha Mihály, Head of Consulting at SMP Solutions. Writing on AI governance, GenAI in banking, and AI transformation in CEE financial services.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="en">
  <section class="home shell">
    <div class="home-mark">Senior consultant · Banking & AI</div>
    <h1 class="home-stmt">
      I help Hungarian and CEE banks adopt AI <em>responsibly</em>.
    </h1>
    <p class="home-sub">
      Writing on AI governance, generative systems in regulated environments, and the actual reality of AI transformation in banking. Long-form, slow, occasional.
    </p>

    <div class="home-grid">
      <div class="home-grid-label">Latest writing</div>
      <div>
        <div class="essay-list">
          {latestEssays.map(essay => (
            <EssayRow
              title={essay.data.title}
              description={essay.data.description}
              date={essay.data.date}
              slug={essay.data.slug}
              pillar={essay.data.pillar}
              languages={[essay.data.language]}
              lang="en"
            />
          ))}
        </div>

        <div class="home-cta">
          <a href="/en/writing/" class="btn-link btn-arrow">All writing</a>
          <span style="margin: 0 12px; color: var(--color-rule-strong);">·</span>
          For inquiries: <a href="/en/contact">see contact</a>. Occasional notes on <a href="https://www.linkedin.com/in/kocziham/" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding-top: var(--space-20);
    padding-bottom: var(--space-32);
  }

  .home-mark {
    font-family: var(--font-sans);
    font-size: var(--fs-13);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .home-stmt {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 8vw, 3.25rem);
    line-height: var(--lh-tight);
    font-weight: var(--fw-medium);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-10) 0;
  }

  .home-stmt em {
    font-style: italic;
    color: var(--color-accent);
  }

  .home-sub {
    font-family: var(--font-serif);
    font-size: var(--fs-22);
    line-height: var(--lh-snug);
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-16) 0;
    max-width: var(--measure-essay);
  }

  .home-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-10);
    margin-top: var(--space-16);
  }

  .home-grid-label {
    font-family: var(--font-sans);
    font-size: var(--fs-13);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }

  .home-cta {
    margin-top: var(--space-10);
    font-size: var(--fs-14);
    color: var(--color-text-muted);
  }

  .home-cta a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .home-cta a:hover {
    text-decoration: underline;
  }

  .btn-link {
    font-weight: var(--fw-medium);
  }

  @media (max-width: 820px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .home-grid-label {
      display: none;
    }

    .home {
      padding-top: var(--space-10);
    }
  }
</style>
